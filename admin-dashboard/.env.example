# Admin Dashboard - copy to .env and set for production build
#
# API base URL of the interview backend.
# - Dev: leave unset to use Vite proxy (localhost:3000 -> /api -> localhost:8000).
# - Production: set to your deployed API URL. No domain needed – use platform URL, e.g.:
#
# VITE_API_URL=https://your-project.railway.app
# VITE_API_URL=https://your-app.onrender.com
# VITE_API_URL=https://your-app.fly.dev
