{
  "name": "interview-agent",
  "private": true,
  "version": "1.0.0",
  "description": "Interview app - fullscreen, no leaving the window",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "vite build && electron .",
    "electron:dev:live": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && cross-env ELECTRON_DEV=1 electron .\"",
    "electron:build": "vite build && electron-builder"
  },
  "dependencies": {
    "ogl": "^1.0.11",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.interview.agent",
    "productName": "Interview Agent",
    "directories": { "output": "release" },
    "files": ["dist", "electron"],
    "win": { "target": "nsis" },
    "nsis": {
      "oneClick": true,
      "installerIcon": null,
      "createDesktopShortcut": true
    }
  }
}
