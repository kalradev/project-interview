# Interview Backend - copy to .env and fill in real values
# Required for production

# App
DEBUG=false
ENVIRONMENT=production

# CORS: comma-separated list of allowed origins (your admin dashboard URL)
# No domain needed – use the URL from Vercel/Netlify, e.g.:
# CORS_ORIGINS=https://your-project.vercel.app
# CORS_ORIGINS=https://your-project.netlify.app
CORS_ORIGINS=

# JWT - REQUIRED: use a long random string (e.g. 32+ chars). Never use default in production.
SECRET_KEY=change-me-use-openssl-rand-hex-32

# PostgreSQL - your production database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-postgres-password
POSTGRES_DB=interview_integrity

# OpenAI (for AI interview questions)
OPENAI_API_KEY=

# Email - Option A: Brevo
BREVO_API_KEY=
BREVO_FROM_EMAIL=

# Email - Option B: SMTP (e.g. Gmail, SendGrid)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=

# Link where candidates download the Interview Agent (optional, for invite emails).
# No domain needed – use GitHub Releases or any file host, e.g.:
# SETUP_APP_DOWNLOAD_URL=https://github.com/your-username/your-repo/releases/latest
SETUP_APP_DOWNLOAD_URL=

# Optional (defaults shown)
# ACCESS_TOKEN_EXPIRE_MINUTES=60
# OPENAI_MODEL=gpt-4o-mini
# UPLOAD_PHOTOS_DIR=uploads/photos
# UPLOAD_VIDEOS_DIR=uploads/videos
