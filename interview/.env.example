# Interview Backend - copy to .env and fill in real values
# Required for production. No localhost is hardcoded; set one of the options below.

# App
DEBUG=false
ENVIRONMENT=production

# CORS: comma-separated list of allowed origins (your admin dashboard URL)
# No domain needed – use the URL from Vercel/Netlify, e.g.:
# CORS_ORIGINS=https://your-project.vercel.app
# CORS_ORIGINS=https://your-project.netlify.app
CORS_ORIGINS=

# JWT - REQUIRED: use a long random string (e.g. 32+ chars). Never use default in production.
SECRET_KEY=change-me-use-openssl-rand-hex-32

# PostgreSQL – use ONE of the two options below (no hardcoded localhost).
#
# Option A (recommended for Render / Supabase): single URL from your provider
# DATABASE_URL=postgresql://postgres:your_password@db.xxxxxx.supabase.co:5432/postgres
# DATABASE_URL=postgresql://user:pass@host.railway.internal:5432/railway
#
# Option B: individual env vars (for local dev use POSTGRES_HOST=localhost)
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# OpenAI (for AI interview questions)
OPENAI_API_KEY=

# Email - Option A: Brevo
BREVO_API_KEY=
BREVO_FROM_EMAIL=

# Email - Option B: SMTP (e.g. Gmail, SendGrid)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=

# Link where candidates download the Interview Agent (optional, for invite emails).
# SETUP_APP_DOWNLOAD_URL=https://github.com/your-username/your-repo/releases/latest
SETUP_APP_DOWNLOAD_URL=

# Browser interview link (optional). When set, invite email includes "Take your interview" link (no install).
# Base URL of the candidate web app (e.g. https://interview.yourdomain.com or Vercel/Netlify URL).
# INTERVIEW_WEB_URL=https://your-interview-app.vercel.app
INTERVIEW_WEB_URL=

# Public API URL returned by /exam/validate so the interview app knows the backend URL (optional).
# If empty, the frontend uses VITE_API_URL from its build.
# API_PUBLIC_URL=https://your-api.onrender.com
API_PUBLIC_URL=

# Optional (defaults shown)
# INTERVIEW_LINK_EXPIRE_DAYS=7
# ACCESS_TOKEN_EXPIRE_MINUTES=60
# OPENAI_MODEL=gpt-4o-mini
# UPLOAD_PHOTOS_DIR=uploads/photos
# UPLOAD_VIDEOS_DIR=uploads/videos
